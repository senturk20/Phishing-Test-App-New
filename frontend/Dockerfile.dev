FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source code
COPY . .

# Vite dev server port
EXPOSE 80

# Start Vite dev server — explicit host/port ensures it binds correctly in Docker.
# CLI args override vite.config.ts if there's any mismatch.
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "80"]
